# ---- Environment ----
ENVIRONMENT=development

# ---- Frontend / CORS ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Database (PostGIS) ----
DATABASE_URL=postgresql+asyncpg://terrax:terrax@db:5432/terrax

# ---- Background jobs ----
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- AI (Groq) ----
# Get a key at https://console.groq.com/keys — leave blank to run without AI.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
